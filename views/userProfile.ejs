
<!DOCTYPE html>
<html>
<head>
  <title>User Profile</title>
</head>
<body>
  <h1>Welcome to Your Profile</h1>
  <h2>Username: <%= user.username %></h2>
  
  <h3>Your Posts:</h3>
  <% if (posts.length === 0) { %>
    <p>No posts found.</p>
  <% } else { %>
    <ul>
      <% posts.forEach((post) => { %>
        <li>
          <h4><%= post.title %></h4>
          <p><%= post.description %></p>
          <p>Tags:
            <% post.tags_name.forEach((tag_name) => { %>
              <%= tag_name %>
            <% }); %>
          </p>
        </li>
      <% }); %>
    </ul>
  <% } %>
</body>
</html>
